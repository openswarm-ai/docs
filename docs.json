{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Open Swarm",
  "colors": {
    "primary": "#ae5630",
    "light": "#c4633a",
    "dark": "#924828"
  },
  "favicon": "/images/logo.png",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Main Site",
          "icon": "globe",
          "href": "https://openswarm.info/"
        },
        {
          "anchor": "Twitter",
          "icon": "x-twitter",
          "href": "https://x.com/OpenSwarm_"
        },
        {
          "anchor": "Discord",
          "icon": "discord",
          "href": "https://discord.gg/NRzxNZW5hH"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/openswarm-ai/openswarm"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "what-is-open-swarm",
              "quickstart"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "approvals",
              "branching",
              "chat-input"
            ]
          },
          {
            "group": "Workspaces",
            "pages": [
              "essentials/overview",
              "essentials/toolbar",
              "essentials/cards",
              "essentials/navigation-1",
              "essentials/selection",
              "essentials/header"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/modes",
              {
                "group": "Skills",
                "icon": "head-side-brain",
                "pages": [
                  "overview",
                  "a",
                  "b"
                ]
              },
              {
                "group": "Actions",
                "icon": "bolt",
                "pages": [
                  "a-1",
                  "b-1",
                  "c",
                  "d"
                ]
              }
            ]
          },
          {
            "group": "Apps",
            "pages": [
              "ai-tools/a",
              "ai-tools/cursor",
              "ai-tools/claude-code"
            ]
          }
        ]
      },
      {
        "tab": "Use Cases",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/LogoDark2.png",
    "dark": "/images/LogoLight2.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@mintlify.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "description": "Your mission control center for Agent swarms.",
  "background": {
    "color": {
      "light": "#F5F5F0",
      "dark": "#1a1918"
    },
    "decoration": "grid"
  },
  "fonts": {
    "family": "Lora"
  }
}
